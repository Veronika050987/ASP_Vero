@page "/movies/create"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@using Microsoft.AspNetCore.Hosting
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

@rendermode InteractiveServer

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Movie</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Movie" OnValidSubmit="AddMovie" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="title" class="form-label">Title:</label>
                <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                <ValidationMessage For="() => Movie.Title" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="releasedate" class="form-label">ReleaseDate:</label>
                <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="genre" class="form-label">Genre:</label>
                <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                <ValidationMessage For="() => Movie.Genre" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="URL" class="form-label">URL:</label>
                <InputText id="URL" @bind-Value="Movie.URL" class="form-control" />
                <ValidationMessage For="() => Movie.URL" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="brief" class="form-label">Brief:</label>
                <InputTextArea id="brief" @bind-Value="Movie.Brief" class="form-control" /> @* Исправлено на InputTextArea для более длинного текста *@
                <ValidationMessage For="() => Movie.Brief" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="posterFile" class="form-label">Poster:</label>
                <InputFile id="posterFile" OnChange="OnPosterFileChange" class="form-control" accept="image/*" />
                @if (previewImageUrl != null)
                {
                    <img src=buffer alt="Poster Preview" style="max-width: 200px; height: auto; margin-top: 10px;" />
                }
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Movie Movie { get; set; } = new();

    private IBrowserFile? selectedPosterFile;
    private string? previewImageUrl; // Для предварительного просмотра

    private void OnPosterFileChange(InputFileChangeEventArgs e)
    {
        selectedPosterFile = e.File;
        if (selectedPosterFile != null)
        {
            // Генерируем URL для предварительного просмотра
            var ms = new MemoryStream();
            selectedPosterFile.OpenReadStream(selectedPosterFile.Size).CopyTo(ms); // Копируем в MemoryStream
            var base64 = Convert.ToBase64String(ms.ToArray());
            previewImageUrl = $"data:{selectedPosterFile.ContentType};base64,{base64}";
        }
        else
        {
            previewImageUrl = null;
        }
        StateHasChanged(); // Обновляем UI для отображения превью
    }

    private async Task AddMovie()
    {
        // 1. Проверяем, что Movie объект не null.
        if (Movie == null)
        {
            // Этого не должно произойти в Create, но для безопасности.
            // Можно либо перейти на страницу ошибок, либо добавить новый Movie.
            Movie = new Movie(); // Или NavigationManager.NavigateTo("errorpage");
        }

        // 2. Обработка постера
        if (selectedPosterFile != null)
        {
            try
            {
                // Проверяем, что размер файла больше 0.
                if (selectedPosterFile.Size > 0)
                {
                    var buffer = new byte[selectedPosterFile.Size];
                    await selectedPosterFile.OpenReadStream().ReadAsync(buffer);

                    Movie.PosterImage = buffer;

                    // Проверяем contentType перед присвоением.
                    // Добавляем проверку на null для selectedPosterFile.ContentType
                    Movie.PosterMimeType = selectedPosterFile.ContentType ?? "application/octet-stream";

                    // Если contentType оказался некорректным, можно установить значение по умолчанию
                    if (string.IsNullOrEmpty(Movie.PosterMimeType))
                    {
                        Movie.PosterMimeType = "application/octet-stream";
                    }
                }
                else
                {
                    // Файл выбран, но он пустой. Обработаем как отсутствие файла.
                    Movie.PosterImage = null;
                    Movie.PosterMimeType = string.Empty; // или null
                }
            }
            catch (Exception ex)
            {
                // Обработка возможных ошибок при чтении файла
                // Например: log.LogError(ex, "Error reading poster file.");
                // Можно уведомить пользователя об ошибке.
                // В данном случае, если файл не прочитался, считаем, что постера нет.
                Movie.PosterImage = null;
                Movie.PosterMimeType = string.Empty; // или null

                // Дополнительно: показать сообщение пользователю
                // _toastService.ShowError($"Could not process image: {ex.Message}");
            }
        }
        else
        {
            // Файл не был выбран. Убедимся, что PosterImage и PosterMimeType установлены в NULL или пусты.
            Movie.PosterImage = null;
            Movie.PosterMimeType = string.Empty; // или null
        }

        // 3. Добавление в базу данных
        try
        {
            using var context = DbFactory.CreateDbContext();
            context.Movie.Add(Movie);
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/movies");
        }
       
        catch (DbUpdateException dbEx)
        {
            // Обработка ошибок при обновлении базы данных (например, конфликты)
            // Log.Error(dbEx, "DB update error while adding movie");
            // Show error message to user
        }
        catch (Exception ex)
        {
            // Обработка общих ошибок
            // Log.Error(ex, "Unexpected error while adding movie");
            // Show error message to user
            // NavigationManager.NavigateTo("/error"); // Или другая страница ошибки
        }
    }
}