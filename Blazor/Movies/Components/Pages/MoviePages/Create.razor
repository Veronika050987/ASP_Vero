@page "/movies/create"
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@using System.IO
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Forms
@rendermode InteractiveServer

@inject HttpClient httpClient

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Movie</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Movie" OnValidSubmit="SaveMovie" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="mb-3">
                <label for="title" class="form-label">Title:</label>
                <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                <ValidationMessage For="() => Movie.Title" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="releasedate" class="form-label">ReleaseDate:</label>
                <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="genre" class="form-label">Genre:</label>
                <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                <ValidationMessage For="() => Movie.Genre" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="URL" class="form-label">URL:</label>
                <InputText id="URL" @bind-Value="Movie.URL" class="form-control" />
                <ValidationMessage For="() => Movie.URL" class="text-danger" />
            </div>

            <div>
                <label for="movieImage">Movie Image:</label>
                <InputFile OnChange="SelectFile" id="movieImage" />
                @if (!string.IsNullOrEmpty(imgUrl))
                {
                    <img src="" alt="Selected Movie Image" style="max-width: 200px; max-height: 200px;" />
                }
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Movie Movie { get; set; } = new();

    private StreamContent? ﬁleContent; // Nullable StreamContent
    private string? ﬁleName;
    private string? imgUrl;
    private string? imageType;

    // HttpClient is injected by default in Blazor Server/WebAssembly projects
    // If you are using a diﬀerent setup, you might need to initialize it.
    // [Inject]
    // private HttpClient HttpClient { get; set; }

    // protected override void OnInitialized()
    // {
    //     base.OnInitialized();

    //     // Initialize HttpClient if not injected
    //     httpClient = new HttpClient(); // Only if not using DI
    // }

    private async Task SelectFile(InputFileChangeEventArgs e)
    {
        long maxFileSize = 1024 * 1024 * 10;// 10Mb 

        try
        {
            //Provide the HTTP Content based stream
            //and open the stream for reading the uploaded file
            ﬁleContent = new StreamContent(e.File.OpenReadStream(maxFileSize));

            //read file name
            ﬁleName = e.File.Name;

            //read the file bytes in sequence
            var fileSize = new byte[e.File.Size];
            await e.File.OpenReadStream().ReadAsync(fileSize);

            //Read file content type
            imageType = e.File.ContentType;

            //Create URL for displaying the image preview
            imgUrl = $"data:{imageType};base64,{Convert.ToBase64String(fileSize)}";

            //Important: do not dispose fileContent here as it will be used later
            //The using statement in UploadFile will handle the disposal

            this.StateHasChanged();
        }
        catch(Exception ex)
        {
            //Handle exceptions, e.g., file too large
            Console.WriteLine($"Error selecting file: {ex.Message}");
            //You might want to show a user-friendly message here
        }
    }

    private async Task SaveMovie()
    {
        using var multipartContent = new MultipartFormDataContent();

        //Add movie details to the form data
        // These keys ("title", "genre", "year") should match what your API expects
        multipartContent.Add(new StringContent(Movie.Title ?? ""), "title");
        multipartContent.Add(new StringContent(Movie.Genre ?? ""), "genre");
        //Add the ﬁle content if a ﬁle was selected  

        if (ﬁleContent != null && !string.IsNullOrEmpty(ﬁleName))
        {
            // Используем HttpContent для файла, чтобы указать имя файла и тип содержимого
            // Имя поля "file" должно совпадать с тем, что ожидает ваш API
            multipartContent.Add(ﬁleContent, "file", ﬁleName);
        }

        try
        {
            // Assuming your API endpoint for creating movies and uploading images
            // is something like POST /api/Movies 
            var response = await httpClient.PostAsync("http://localhost:5000/api/Movies", multipartContent);

            if(response.IsSuccessStatusCode)
            {
                //Successfully created movie. You might want to naviagate to the list page
                Console.WriteLine("Movie created successfully!");
                //await Navigationmanager.NavigateTo("/movies");//if you have Navigationmanager injected
            }
            else
            {
                //Handle API errors 
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"API Error:{response.StatusCode} - {errorContent}");
                //Display an error message to the user
            }
        }
        catch(Exception ex)
        {
            //Handle network or other exceptions
            Console.WriteLine($"An error occured: {ex.Message}");
            //Display an error message to the user
        }
        finally
        {
            //Dispose of the StreamContent after the request in sent
            ﬁleContent?.Dispose();
            ﬁleContent = null;
        }
    }
}