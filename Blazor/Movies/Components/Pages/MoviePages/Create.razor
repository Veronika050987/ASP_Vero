            }
            else
            {
                // Обработка ошибки, если тип fileContent не поддерживается
                // Или если fileContent не является Stream или byte[]
                throw new InvalidOperationException("Unsupported file content type.");
            }

            // The name parameter should match what your API expects for the file field
            // Убедитесь, что "file" - это правильное имя поля
            multipartContent.Add(httpFileContent, "file", fileName);
        }
        try
        {
            var response = await httpClient.PostAsync("http://localhost:5000/api/Movies", multipartContent);
            response.EnsureSuccessStatusCode(); // Проверить на ошибки HTTP
        }
        catch (HttpRequestException e)
        {
            // Обработка ошибок HTTP
            Console.WriteLine($"Request error: {e.Message}");
        }
        catch (Exception e)
        {
            // Обработка других ошибок
            Console.WriteLine($"An error occurred: {e.Message}");
        }

    }
}