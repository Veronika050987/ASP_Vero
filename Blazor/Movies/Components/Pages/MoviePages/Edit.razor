@page "/movies/edit"
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@inject HttpClient httpClient
@inject IJSRuntime JSRuntime

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Movie</h2>
<hr />
@if (Movie is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Movie" OnValidSubmit="UpdateMovie" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />
                <input type="hidden" name="Movie.Id" value="@Movie.Id" />
                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                    <ValidationMessage For="() => Movie.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="releasedate" class="form-label">ReleaseDate:</label>
                    <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                    <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                    <ValidationMessage For="() => Movie.Genre" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="url" class="form-label">URL:</label>
                    <InputText id="url" @bind-Value="Movie.URL" class="form-control" />
                    <ValidationMessage For="() => Movie.URL" class="text-danger" />
                </div>
                    <label for="movieImage">Movie Image (Upload new to replace):</label>
                    <InputFile OnChange="SelectFile" id="movieImage" />
                    @if (!string.IsNullOrEmpty(Movie.ImageUrl))
                    {
                        <p>Current Image:</p>
                        <img src="" alt="Current Movie Image" style="max-width: 200px; max-height: 200px;" />
                    }
                    @if (!string.IsNullOrEmpty(Movie.ImageUrl))
                    {
                        <p>New Image Preview:</p>
                        <img src="" alt="Selected New Movie Image" style="max-width: 200px; max-height: 200px;" />
                    }
                <button type="submit" class="btn btn-primary">Update Movie</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Movie? Movie { get; set; }

    private StreamContent? fileContent;
    private string? fileName;
    private string? imageUrl;
    private string? imageType;
    private string? originalImageUrl; //to store the URL of the existing image



    protected override async Task OnInitializedAsync()
    {
        await LoadMovieForEditing();
    }

    private async Task LoadMovieForEditing()
    {
        try
        {
            var response = await httpClient.GetAsync($"http://localhost:5000/api/Movies/{Id}");

            if(response.IsSuccessStatusCode)
            {
                Movie = await response.Content.ReadFromJsonAsync<Movie>();
            }

            else
            {
                Console.WriteLine($"API Errorloading movie {Id} for editing: {response.StatusCode}");
                Movie = null;
            }
        }
        catch(Exception ex)
        {
            Console.WriteLine($"An error occured during loading movie for editing: {ex.Message}");
            Movie = null;
        }
    }
    private async Task SelectFile(InputFileChangeEventArgs e)
    {
        long maxFileSize = 1024 * 1024 * 10;

        try
        {
            fileContent = new StreamContent(e.File.OpenReadStream(maxFileSize));

            fileName = e.File.Name;
            imageType = e.File.ContentType;

            var fileSize = new byte[e.File.Size];
            await e.File.OpenReadStream().ReadAsync(fileSize);
            imageUrl = $"data:{imageType};base64,{Convert.ToBase64String(fileSize)}";

            // Important: Do not dispose ﬁleContent here
            this.StateHasChanged();
        }
        catch(Exception ex)
        {
            Console.WriteLine($"Error selecting ﬁle: {ex.Message}");

            // Show user-friendly error 
        }
    }
    private async Task UpdateMovie()
    {
        using var multipartContent = new MultipartFormDataContent();

        // Add updated movie details
        multipartContent.Add(new StringContent(Movie.Title ?? ""), "title");

        multipartContent.Add(new StringContent(Movie.Genre ?? ""), "genre");

        // Add the new image if one was selected
        if(fileContent != null && !string.IsNullOrEmpty(fileName))
        {
            multipartContent.Add(fileContent, "file", fileName);
        }
        else
        {
            //if no new image was uploaded we still need to send the original URL
            //so the backend knows not to remove the existing image
            //If your API expects null for no image adjust this.
            //For simplicity we are not explicitly sending originalImageUrl here,
            //assuming the backend handles cases where "ﬁle" is not present.
            //If your API requires it, you might need a separate ﬁeld for originalImageUrl
            //or handle it diﬀerently.

            if(!string.IsNullOrEmpty(originalImageUrl))
            {
                //This is a common scenario: send the new ﬁle if available.
                //If no new ﬁle, the backend should ideally use the existing one.
                //If your API design requires sending the original URL to keep it,
                //you'd add it as another StringContent.
            }
        }
        try
        {
            //supported endpoint for movi update by ID
            var response = await httpClient.PutAsync($"http://localhost:5000/api/Movies/{Id}", multipartContent);

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Movie updated successfully!");
                NavigationManager.NavigateTo($"/movies/details/{Id}");//details
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"API Error updating movie {Id}: {response.StatusCode} - {errorContent}"); 
                //Message for a user
            }
        }
        catch(Exception ex)
        {
            Console.WriteLine($"An error occurred updating movie: {ex.Message}");
            //Message for a user
        }
        finally
        {
            //Dispose StreamContent afer the request is sent
            fileContent?.Dispose();
            fileContent = null;
        }
    }
}