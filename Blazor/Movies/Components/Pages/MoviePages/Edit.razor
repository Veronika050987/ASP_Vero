@page "/movies/edit"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@using Microsoft.AspNetCore.Hosting
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Movie</h2>
<hr />
@if (Movie is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Movie" OnValidSubmit="UpdateMovie" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />
                <input type="hidden" name="Movie.Id" value="@Movie.Id" />

                @* Отображение текущего изображения, если оно есть *@
                <div class="mb-3">
                    <label>Current Poster:</label><br />
                    @if (Movie.PosterImage != null && Movie.PosterImage.Length > 0)
                    {
                        var base64 = Convert.ToBase64String(Movie.PosterImage);
                        // Обеспечиваем, что PosterMimeType не null и имеет значение по умолчанию
                        var mimeType = !string.IsNullOrEmpty(Movie.PosterMimeType) ? Movie.PosterMimeType : "application/octet-stream";
                        var imgTag = $"data:{mimeType};base64,{base64}";
                        <img src="" alt="Current Poster" style="max-width: 200px; height: auto;" />
                        <br />
                    }
                    else
                    {
                        <span>No current poster available.</span>
                        <br />
                    }
                </div>

                <div class="mb-3">
                    <label for="posterFile" class="form-label">Change Poster (optional):</label>
                    <InputFile id="posterFile" OnChange="OnPosterFileChange" class="form-control" accept="image/*" />
                    @* Предварительный просмотр нового выбранного изображения *@
                    @if (!string.IsNullOrEmpty(previewImageUrl))
                    {
                        <p>Preview of new image:</p>
                        <img src=Movie.PosterImage alt="New Poster Preview" style="max-width: 200px; height: auto; margin-top: 10px;" />
                        <br />
                    }
                </div>

                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                    <ValidationMessage For="() => Movie.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="releasedate" class="form-label">ReleaseDate:</label>
                    <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                    <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                    <ValidationMessage For="() => Movie.Genre" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="url" class="form-label">URL:</label>
                    <InputText id="url" @bind-Value="Movie.URL" class="form-control" />
                    <ValidationMessage For="() => Movie.URL" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="brief" class="form-label">Brief:</label>
                    <InputTextArea id="brief" @bind-Value="Movie.Brief" class="form-control" />
                    <ValidationMessage For="() => Movie.Brief" class="text-danger" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Movie? Movie { get; set; }

    private IBrowserFile? selectedPosterFile; // Для хранения нового выбранного файла
    private string? previewImageUrl; // Для предварительного просмотра нового изображения

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        // Загружаем Movie, включая PosterImage и PosterMimeType
        Movie = await context.Movie.FindAsync(Id);

        if (Movie is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private void OnPosterFileChange(InputFileChangeEventArgs e)
    {
        selectedPosterFile = e.File;
        if (selectedPosterFile != null)
        {
            try
            {
                var ms = new MemoryStream();
                selectedPosterFile.OpenReadStream(selectedPosterFile.Size).CopyTo(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                // Используем ContentType для формирования Data URL
                previewImageUrl = $"data:{selectedPosterFile.ContentType ?? "application/octet-stream"};base64,{base64}";
            }
            catch (Exception ex)
            {
                // Обработка ошибки при чтении файла для превью
                previewImageUrl = null;
                // Log.Error(ex, "Error creating preview image.");
            }
        }
        else
        {
            previewImageUrl = null;
        }
        StateHasChanged(); // Обновляем UI для отображения превью
    }

    private async Task UpdateMovie()
    {
        if (Movie is null) return;

        if (selectedPosterFile != null)
        {
            try
            {
                // Проверяем, что файл не пустой
                if (selectedPosterFile.Size > 0)
                {
                    var buffer = new byte[selectedPosterFile.Size];
                    await selectedPosterFile.OpenReadStream().ReadAsync(buffer);

                    Movie.PosterImage = buffer;
                    // Обеспечиваем, что PosterMimeType не null
                    Movie.PosterMimeType = selectedPosterFile.ContentType ?? "application/octet-stream";
                    if (string.IsNullOrEmpty(Movie.PosterMimeType))
                    {
                        Movie.PosterMimeType = "application/octet-stream";
                    }
                }
                else
                {
                    // Если выбранный файл пустой, считаем, что пользователь не выбрал новое изображение.
                    // Старое изображение остается без изменений.
                    // Ничего не делаем, если selectedPosterFile.Size == 0.
                }
            }
            catch (Exception ex)
            {
                // Обработка ошибки при чтении файла для сохранения
                // Log.Error(ex, "Error reading poster file for update.");
                // Откатываем изменения для постера, если произошла ошибка
                // Можно вернуть старое значение, если оно было загружено
                // Если Movie.PosterImage был null, он останется null.
                // Если он был с данными, эти данные не будут обновлены.
            }
        }
        // Если selectedPosterFile == null, старое изображение остается без изменений.

        using var context = DbFactory.CreateDbContext();
        context.Attach(Movie).State = EntityState.Modified;
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo($"/movies/details?id={Id}"); // Перенаправляем на страницу деталей
    }
}