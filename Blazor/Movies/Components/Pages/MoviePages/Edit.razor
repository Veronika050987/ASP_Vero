@page "/movies/edit"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Movie</h2>
<hr />
@if (Movie is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Movie" OnValidSubmit="UpdateMovie" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Movie.Id" value="@Movie.Id" />
                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                    <ValidationMessage For="() => Movie.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="releasedate" class="form-label">ReleaseDate:</label>
                    <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                    <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                    <ValidationMessage For="() => Movie.Genre" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">URL:</label>
                    <InputText id="genre" @bind-Value="Movie.URL" class="form-control" />
                    <ValidationMessage For="() => Movie.URL" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="brief" class="form-label">Brief:</label>
                    <InputText id="brief" @bind-Value="Movie.Brief" class="form-control" />
                    <ValidationMessage For="() => Movie.Brief" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label>Current Poster:</label><br />
                    @if (!string.IsNullOrEmpty(Movie.Poster))
                    {
                        <img src="" style="max-width: 200px;" />
                
                        <br />
                    }
                    <label for="imagefile" class="form-label">Change Poster:</label>
                    <InputFile id="imagefile" OnChange="LoadFiles" class="form-control" accept="image/*" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/movies">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Movie? Movie { get; set; }

    private IBrowserFile? uploadedFile;

    // Инъекция Environment добавлена вверху @inject IWebHostEnvironment Environment

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Movie ??= await context.Movie.FirstOrDefaultAsync(m => m.Id == Id);

        if (Movie is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private void LoadFiles(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
    }

    private async Task UpdateMovie()
    {
        if (uploadedFile != null)
        {
            // 1. Создаем папку, если нет
            string uploadsFolder = Path.Combine(Environment.WebRootPath, "movie_posters");
            if (!Directory.Exists(uploadsFolder)) Directory.CreateDirectory(uploadsFolder);

            // 2. Генерируем имя и сохраняем
            string uniqueFileName = Guid.NewGuid().ToString() + "_" + uploadedFile.Name;
            string filePath = Path.Combine(uploadsFolder, uniqueFileName);

            await using FileStream fs = new(filePath, FileMode.Create);
            await uploadedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5).CopyToAsync(fs);

            // 3. Удаляем старый файл, если он был (опционально)
            if (!string.IsNullOrEmpty(Movie.Poster))
            {
                var oldFilePath = Path.Combine(Environment.WebRootPath, Movie.Poster.TrimStart('/'));
                if (File.Exists(oldFilePath)) File.Delete(oldFilePath);
            }

            // 4. Обновляем путь в модели
            Movie.Poster = "/movie_posters/" + uniqueFileName;
        }

        using var context = DbFactory.CreateDbContext();
        context.Attach(Movie!).State = EntityState.Modified;
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/movies");
    }

    private bool MovieExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Movie.Any(e => e.Id == id);
    }
}
