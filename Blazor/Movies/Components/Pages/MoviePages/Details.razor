@page "/movies/details"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Movies.Models
@using Microsoft.AspNetCore.Hosting
@inject IDbContextFactory<Movies.Data.MoviesContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

<PageTitle>Details</PageTitle>

<h1>Details</h1>

@if (movie is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h2>Movie details</h2>
    <hr />
    <div class="info">
        <div>
            <dl class="row">
                <dt class="name col-sm-2">Title</dt>
                <dd class="col-sm-10">@movie.Title</dd>
                <dt class="name col-sm-2">ReleaseDate</dt>
                <dd class="col-sm-10">@movie.ReleaseDate</dd> 
                <dt class="name col-sm-2">Genre</dt>
                <dd class="col-sm-10">@movie.Genre</dd>
                <dt class="name col-sm-2">URL</dt>
                <dd class="col-sm-10"><a href=@movie.URL>@movie.URL</a></dd>
                <dt class="name col-sm-2">Brief</dt>
                <dd class="col-sm-10">@movie.Brief</dd>
                <div>
                    <dt class="col-sm-2">Poster</dt>
                    <dd class="col-sm-10">
                        @if (movie.PosterImage != null && movie.PosterImage.Length > 0)
                        {
                            var base64 = Convert.ToBase64String(movie.PosterImage);
                            // Обеспечиваем, что PosterMimeType не null и имеет значение по умолчанию, если он пустой
                            var mimeType = !string.IsNullOrEmpty(movie.PosterMimeType) ? movie.PosterMimeType : "application/octet-stream";
                            var imgTag = $"data:{mimeType};base64,{base64}";

                            @* Исправлено: используется сгенерированный imgTag *@
                            <img src="" alt="Poster" style="max-width: 300px; height: auto;" />
                        }
                        else
                        {
                            <span>No image available</span>
                        }
                    </dd>
                </div>
            </dl>
        </div>
    </div>
    <div>
        <a href="@($"/movies/edit?id={movie.Id}")">Edit</a> |
        <a href="@($"/movies")">Back to List</a>
    </div>
}

@code {
    private Movie? movie;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Загружаем PosterImage и PosterMimeType, если они есть.
        // FindAsync найдет запись по ключу.
        // Если PosterImage и PosterMimeType не были загружены явно,
        // они могут быть null. EF Core может подгрузить их по необходимости,
        // но иногда лучше явно указать, что нужно загрузить.
        // Для простоты, если вы не меняли настройки EF Core, FindAsync должен работать.

        movie = await context.Movie.FindAsync(Id);

        if (movie is null)
        {
            // Если фильм не найден, перенаправляем на страницу "не найдено".
            NavigationManager.NavigateTo("notfound");
        }
    }
}