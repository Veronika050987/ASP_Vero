﻿@using Microsoft.AspNetCore.Components.Routing
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Academy2</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Counter
            </NavLink>
        </div>

        <ul class="nav flex-column">
            <li class="nav-item px-3 mt-3 text-white">
                <img src="svg/academy.svg" alt="Icon" style="width: 20px; height: 20px; " />
                <strong>Academy</strong>
            </li>

            <li class="nav-item px-3 mt-3">
                <NavLink class="nav-link" href="students" Match="MatchMode">
                    <img src="svg/stud.svg" alt="Icon" style="width: 20px; height: 20px;" />
                    Students
                </NavLink>
            </li>
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="groups" Match="MatchMode">
                    <img src="svg/group.svg" alt="Icon" style="width: 20px; height: 20px;" />
                    Groups
                </NavLink>
            </li>

            <li class="nav-item px-3">
                <NavLink class="nav-link" href="directions" Match="MatchMode">
                    <img src="svg/direction.svg" alt="Icon" style="width: 20px; height: 20px;" />
                    Directions
                </NavLink>
            </li>

            <li class="nav-item px-3">
                <NavLink class="nav-link" href="teachers" Match="MatchMode">
                    <img src="svg/teacher.svg" alt="Icon" style="width: 20px; height: 20px;" />
                    Teachers
                </NavLink>
            </li>

        </ul>

        @* <div class="nav-item px-3">
            <NavLink class="nav-link" href="directions">
                <img src="svg/direction.svg" alt="Icon" style="width: 20px; height: 20px;" /> Directions
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="groups">
                <img src="svg/group.svg" alt="Icon" style="width: 20px; height: 20px;" /> Groups
            </NavLink>
        </div> *@

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Weather
            </NavLink>
        </div>
    </nav>
</div>
@code {
    private NavLinkMatch MatchMode { get; set; } = NavLinkMatch.All;
}

