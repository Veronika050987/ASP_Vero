@page "/teachers/create"
@using Microsoft.EntityFrameworkCore
@using Academy2.Components.Models
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Teacher</h2>
<hr />
<div class="row">
    <div>
        <EditForm method="post" Model="Teacher" OnValidSubmit="AddTeacher" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            
            <div class="human-container">
				<div class="col-md-4">
                    <input type="number" name="Teacher.teacher_id" @bind="Teacher.teacher_id" />
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="last_name" class="form-label">last_name:</label>
                        <InputText id="last_name" @bind-Value="Teacher.last_name" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Teacher.last_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="first_name" class="form-label">first_name:</label>
                        <InputText id="first_name" @bind-Value="Teacher.first_name" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Teacher.first_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="middle_name" class="form-label">middle_name:</label>
                        <InputText id="middle_name" @bind-Value="Teacher.middle_name" class="form-control" />
                        <ValidationMessage For="() => Teacher.middle_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="birth_date" class="form-label">birth_date:</label>
                        <InputDate id="birth_date" @bind-Value="Teacher.birth_date" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Teacher.birth_date" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">email:</label>
                        <InputText id="email" @bind-Value="Teacher.email" class="form-control" />
                        <ValidationMessage For="() => Teacher.email" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">phone:</label>
                        <InputText id="phone" @bind-Value="Teacher.phone" class="form-control" />
                        <ValidationMessage For="() => Teacher.phone" class="text-danger" />
                    </div>
                    @*   <div class="mb-3">
                    <label for="photo" class="form-label">photo:</label>
                    <InputText id="photo" @bind-Value="Teacher.photo" class="form-control" />
                    <ValidationMessage For="() => Teacher.photo" class="text-danger" />
                    </div>   *@
                    <div class="mb-3">
                        <label for="work_since" class="form-label">work_since:</label>
                        <InputDate id="work_since" @bind-Value="Teacher.work_since" class="form-control" />
                        <ValidationMessage For="() => Teacher.work_since" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="rate" class="form-label">rate:</label>
                        <InputNumber id="rate" @bind-Value="Teacher.rate" class="form-control" />
                        <ValidationMessage For="() => Teacher.rate" class="text-danger" />
                    </div>
                </div>
                <div class="photo-container">
                    <Photo Human="@Teacher" allow_change=true />
                </div>
                <div class="mb-3">
                    <label for="disciplines">Disciplines</label>
                    <InputSelect @bind-Value="Teacher.SelectedDisciplineIdAsString" class="form-control" id="disciplines">
                     <option value="" disabled>Please, choose a discipline</option>
                        @if (Disciplines != null)
                     {
                            @foreach (Discipline d in Disciplines)
                            {
                                <option value="@d.discipline_id.ToString()">@d.discipline_name</option>
                            }
                     }
                    </InputSelect>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/teachers">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Teacher Teacher { get; set; } = new();

    private List<Discipline> Disciplines { get; set; } = new();

    private string? SelectedDisciplineIdAsString { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Disciplines = await context.Disciplines.ToListAsync();

        if(Teacher.teacher_id != 0)
        {
            var teacherDisciplineRelation = await context.TeachersDisciplinesRelation
                        .FirstOrDefaultAsync(tdr => tdr.teacher == Teacher.teacher_id);
            if(teacherDisciplineRelation != null)
            {
                SelectedDisciplineIdAsString = teacherDisciplineRelation.discipline.ToString();
                Teacher.SelectedDisciplineIdAsString = SelectedDisciplineIdAsString;
            }
        }

    }

    // This method will be called when the form is submitted
    private async Task HandleFormSubmit()
    {
        // Convert the selected discipline ID back to an integer and add to SelectedDisciplineIds
        if(!string.IsNullOrEmpty(Teacher.SelectedDisciplineIdAsString))
        {
            if(int.TryParse(Teacher.SelectedDisciplineIdAsString, out int disciplineId))
            {
                // Clear existing selections to avoid duplicates
                Teacher.SelectedDisciplineIds.Clear();
                Teacher.SelectedDisciplineIds.Add(disciplineId);
            }
        }
    }

    private async Task AddTeacher()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        int selectedDisciplineId = 0;
        if (!string.IsNullOrEmpty(Teacher.SelectedDisciplineIdAsString))
        {
            if (int.TryParse(Teacher.SelectedDisciplineIdAsString, out int disciplineId))
            {
                selectedDisciplineId = disciplineId;
            }
            else
            {
                Console.WriteLine($"Error: Invalid discipline ID format: {Teacher.SelectedDisciplineIdAsString}");
                return;
            }
        }

        Teacher.SelectedDisciplineIds.Clear();
        if (selectedDisciplineId != 0)
        {
            Teacher.SelectedDisciplineIds.Add(selectedDisciplineId);
        }

        context.Teachers.Add(Teacher);

        if (selectedDisciplineId != 0)
        {
            var teacherDisciplineRelation = new TeacherDisciplineRelation
            {
                discipline = selectedDisciplineId
            };
            if (Teacher.DisciplinesRelations == null)
            {
                Teacher.DisciplinesRelations = new List<TeacherDisciplineRelation>();
            }
            Teacher.DisciplinesRelations.Add(teacherDisciplineRelation);
        }
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/teachers");
    }
}
