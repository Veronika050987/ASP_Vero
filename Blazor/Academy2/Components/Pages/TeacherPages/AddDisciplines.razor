@using Academy2.Components.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@rendermode InteractiveServer

<h3>AddDisciplines</h3>
<div class="mb-3" style="align-content:center;height:30vh">
    <h5>Выберите дисциплину:</h5>
    <InputSelect @bind-Value="discipline" class="form-control">
        <option selected disabled value="-1">--- Выберите дисциплину ---</option>
        @if (Disciplines != null)
        {
            @foreach (Discipline d in Disciplines)
            {
                @if (TDR.Any(tdr => tdr.discipline == d.discipline_id) || NewDisciplines.Any(nd => nd.discipline == d.discipline_id)) continue;
                <option value="@d.discipline_id">@d.discipline_name</option>
            }
        }
    </InputSelect>
    <button type="button" class="btn btn-primary" @onclick="AddDiscipline" disabled="@(discipline == -1 || Teacher == null)">Добавить</button>
    @if (!string.IsNullOrEmpty(feedbackMessage))
    {
        <div class="alert @(feedbackMessage.Contains("успешно") ? "alert-success" : "alert-danger")" role="alert">
            @feedbackMessage
        </div>
    }

    <hr />
    <ul>
        @if (Disciplines != null)
        {
            @foreach (var d in Disciplines)
            {
                @if (NewDisciplines.Any(nd => nd.discipline == d.discipline_id))
                {
                    <li>@d.discipline_name</li>
                }
            }
        }
    </ul>
    <hr />
    <ul>
        @if (TDR != null)
        {
            @foreach (var tdr in TDR)
            {
                <li>@tdr.Discipline.discipline_name</li>
            }
        }
    </ul>
</div>

@code {
    [Parameter]
    public Models.Teacher? Teacher { get; set; }
    ICollection<Discipline> Disciplines { get; set; }
    ICollection<TeacherDisciplineRelation> TDR { get; set; }
    List<TeacherDisciplineRelation> NewDisciplines = new List<TeacherDisciplineRelation>();
    int discipline = -1;
    private string feedbackMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // using var context = DbFactory.CreateDbContext();
        // Disciplines = await context.Disciplines.ToListAsync();
        // TDR = await context.TeachersDisciplinesRelation.Where(t => t.teacher == Teacher.teacher_id).ToListAsync();
        if (Teacher != null)
        {
            await LoadData();
        }
    }

    public async Task LoadData(Models.Teacher teacherInstance)
    {
        Teacher = teacherInstance;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (Teacher == null) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            Disciplines = await context.Disciplines.ToListAsync();
            TDR = await context.TeachersDisciplinesRelation
                .Where(t => t.teacher == Teacher.teacher_id)
                .Include(t => t.Discipline)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            feedbackMessage = $"Ошибка при загрузке данных: {ex.Message}";
            Console.WriteLine(ex.Message);
        }
    }

    void AddDiscipline()
    {
        if (discipline == -1 || Teacher == null) return;

        if (NewDisciplines.Any(d => d.discipline == discipline))
        {
            feedbackMessage = "Дисциплина уже добавлена.";
            return;
        }

        if (TDR.Any(tdr => tdr.discipline == discipline))
        {
            feedbackMessage = "Дисциплина уже назначена учителю.";
            return;
        }

        TeacherDisciplineRelation newRelation = new TeacherDisciplineRelation
        {
            teacher = Teacher.teacher_id,
            discipline = discipline
        };

        NewDisciplines.Add(newRelation);
        feedbackMessage = "Дисциплина добавлена в список.";
        discipline = -1;
    }

    public async Task Update()
    {
        if (NewDisciplines.Any())
        {
            using var context = DbFactory.CreateDbContext();
            await context.TeachersDisciplinesRelation.AddRangeAsync(NewDisciplines);
            await context.SaveChangesAsync();
            feedbackMessage = "Новые дисциплины сохранены.";
            NewDisciplines.Clear(); // Очищаем список после сохранения
            // Перезагружаем TDR, чтобы увидеть изменения в UI компонента
            TDR = await context.TeachersDisciplinesRelation
                .Where(t => t.teacher == Teacher.teacher_id)
                .Include(t => t.Discipline)
                .ToListAsync();
        }
        else
        {
            feedbackMessage = "Нет новых дисциплин для сохранения.";
        }
    }

}
